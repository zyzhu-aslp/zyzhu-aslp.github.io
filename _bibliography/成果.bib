@inproceedings{Yu2021boundary,
  title        = {Boundary and Context Aware Training for CIF-based Non-Autoregressive End-to-end ASR},
  author       = {Yu, Fan and Luo, Haoneng and Guo, Pengcheng and Liang, Yuhao and Yao, Zhuoyuan and Xie, Lei and Gao, Yingying and Hou, Leijing and Zhang, Shilei},
