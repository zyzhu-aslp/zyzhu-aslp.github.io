source 'https://rubygems.org'

# Ruby 4.0+ 起 logger 不再随 Ruby 默认提供，Jekyll 4.3.x 需显式加入 Gemfile
gem 'logger'
# Ruby 3.4+ 起 observer 移出默认库，citeproc-ruby / jekyll-scholar 依赖它
gem 'observer'
# Ruby 4.0+ 起 ostruct 移出默认库，jekyll-twitter-plugin 依赖它
gem 'ostruct'

group :jekyll_plugins do
    gem 'classifier-reborn'
    gem 'jekyll'
    gem 'jekyll-archives'
    gem 'jekyll-email-protect'
    gem 'jekyll-feed'
    gem 'jekyll-get-json'
    gem 'jekyll-imagemagick'
    gem 'jekyll-jupyter-notebook'
    gem 'jekyll-link-attributes'
    gem 'jekyll-minifier'
    gem 'jekyll-paginate-v2'
    gem 'jekyll-regex-replace'
    gem 'jekyll-scholar'
    gem 'jekyll-sitemap'
    gem 'jekyll-tabs'
    gem 'jekyll-toc'
    gem 'jekyll-twitter-plugin'
    gem 'jemoji'
    gem 'mini_racer'
    gem 'unicode_utils'
    gem 'webrick'
end
group :other_plugins do
    gem 'css_parser'
    gem 'feedjira'
    gem 'httparty'
end
